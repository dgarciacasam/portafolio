---
import TechPill from './TechPill.astro'

interface Props {
    title: string
    description: string
    link:string
    tag: string
    date: string
}

const { title, description, link, tag, date } = Astro.props
---
<article class="border border-white/30 rounded p-3">
    <h3 class="flex space-x-1 text-lg hover:underline hover:decoration-dashed hover:decoration-white/50 hover:underline-offset-4">
        <a href={link} target="_blank" class="font-bold">{title}</a>
    </h3>
    <p class="mt-1 text-white/70 text-sm text-pretty">{description}</p>
    <div class="flex justify-between items-center mt-4">
        <TechPill name={tag} />
        <p class="text-white/70 text-sm">{date}</p>
    </div>
</article>